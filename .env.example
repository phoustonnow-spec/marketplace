# ─── Copy this file to .env.local and fill in your own values ───

# The root domain your app runs on. Locally use "localhost:3000".
# In production set this to "market.place".
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ─── Supabase (Project Settings → API) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe (Developers → API keys) ───
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Price ID for the $4/month seller subscription (create it in Stripe → Products).
STRIPE_PRICE_ID=price_xxx
# Webhook signing secret (Developers → Webhooks → your endpoint).
STRIPE_WEBHOOK_SECRET=whsec_xxx
